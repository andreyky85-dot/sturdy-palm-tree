# Переменные для Vercel (Settings → Environment Variables)
# Скопируйте имена и подставьте свои значения в дашборде Vercel.
# После первого деплоя замените ваш-домен.vercel.app на реальный URL проекта.

DATABASE_URL=
# ↑ Часто подставляется автоматически при подключении Vercel Postgres к проекту

OPENAI_API_KEY=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

NEXTAUTH_URL=https://ваш-домен.vercel.app
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_APP_URL=https://ваш-домен.vercel.app

# Rate limit по IP (Upstash Redis или Vercel KV)
